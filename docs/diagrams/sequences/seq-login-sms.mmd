sequenceDiagram
    title 用户登录与短信验证码时序图
    autonumber
    actor 用户
    participant 前端
    participant LoginController
    participant Redis
    participant LoginService
    participant UserService

    rect rgb(245, 247, 250)
        note over 用户,Redis: 注册前短信验证码流程
        用户->>前端: 输入手机号并发送验证码
        前端->>LoginController: POST /api/sms/send-code
        LoginController->>Redis: setIfAbsent(lockKey, 60s)
        alt 60 秒内已发送过
            Redis-->>LoginController: false + ttl
            LoginController-->>前端: 返回 remaining 秒数
            前端-->>用户: 提示稍后重试
        else 允许发送
            LoginController->>Redis: set(code, 300s)
            LoginController-->>前端: 验证码已发送
            前端-->>用户: 提示验证码已发送
        end
        用户->>前端: 输入验证码并提交
        前端->>LoginController: POST /api/sms/verify-code
        LoginController->>Redis: get(sms:code:phone)
        Redis-->>LoginController: storedCode
        LoginController-->>前端: true / false
    end

    rect rgb(250, 250, 245)
        note over 用户,UserService: 注册与登录主流程
        用户->>前端: 输入注册信息
        前端->>LoginController: POST /api/register
        LoginController->>LoginService: register(username, password, phone)
        alt 用户名已存在
            LoginService-->>LoginController: false
            LoginController-->>前端: 409 用户名已存在
        else 注册成功
            LoginService-->>LoginController: true
            LoginController-->>前端: 201 注册成功
        end

        用户->>前端: 输入用户名和密码
        前端->>LoginController: POST /api/login
        LoginController->>LoginService: validateLogin(username, password)
        alt 账号或密码错误
            LoginService-->>LoginController: false
            LoginController-->>前端: 401 用户名或密码错误
        else 登录成功
            LoginService-->>LoginController: true
            LoginController->>UserService: getUserIdByName(username)
            UserService-->>LoginController: userId
            LoginController-->>前端: token + userId + userName
            前端-->>用户: 进入系统首页
        end
    end
